---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

// Contact runs through Web3Forms (static-friendly relay). The destination
// inbox is whatever address was used to generate this access key at
// web3forms.com — swap the key to change where submissions land.
const web3formsKey = "62e8369d-ecf1-45f1-b3a3-20c9f6db36e9";
const repo = "https://github.com/usesalvager/salvager";
---

<Layout
  title="Salvager for teams: free and open, talk to us if you need more"
  description="The full binary, every feature, free and open-source forever. If you run Salvager across a team or in production and need more than the open binary gives you, tell us what you need. Salvager Fleet — a local-first, BYOC read-only view of agent activity across machines — is in early access."
>
  <Header />

  <main id="main">
    <!-- Hero -->
    <section class="border-b border-ink-800/60">
      <div class="mx-auto max-w-5xl px-6 pt-20 pb-16 sm:pt-24">
        <p class="font-mono text-sm text-accent-400">For teams and production</p>
        <h1
          class="mt-4 max-w-3xl text-balance text-4xl font-semibold leading-[1.1] tracking-tight text-ink-100 sm:text-5xl"
        >
          Salvager is free and open-source.
        </h1>
        <p class="mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-ink-300">
          The full binary, every feature, forever. Apache-2.0, self-hosted, no
          telemetry. Nothing here costs money, and nothing phones home.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href="#contact"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-500 px-5 py-3 font-medium text-ink-950 transition-colors hover:bg-accent-400"
          >
            Tell us what you're running
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a
            href={repo}
            class="inline-flex items-center justify-center gap-2 rounded-lg border border-ink-700 px-5 py-3 font-medium text-ink-100 transition-colors hover:border-ink-600 hover:bg-ink-850"
          >
            View the source
          </a>
        </div>
      </div>
    </section>

    <!-- The open ask -->
    <section class="border-b border-ink-800/60 bg-ink-900/40">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <h2
          class="max-w-3xl text-balance text-2xl font-semibold leading-snug tracking-tight text-ink-100 sm:text-3xl"
        >
          Running it across a team, or depending on it in production?
        </h2>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-300">
          If you need more than the open binary gives you — help getting it
          deployed, someone on the hook when it matters, or something we haven't
          built yet — tell us what you're running and what you need.
        </p>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink-400">
          We build what real users actually ask for, scoped per conversation. No
          public pricing, no sales pressure, no obligation. The core stays free
          either way — whatever we'd do for you sits on top of it.
        </p>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink-400">
          People reach out about deployment, supervised setups across machines,
          and response-time commitments — but the list is open. If what you need
          isn't on it, tell us anyway.
        </p>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="border-b border-ink-800/60 scroll-mt-24">
      <div class="mx-auto max-w-2xl px-6 py-20">
        <h2
          class="text-balance text-2xl font-semibold leading-snug tracking-tight text-ink-100 sm:text-3xl"
        >
          Tell us what you're running.
        </h2>
        <p class="mt-3 text-base leading-relaxed text-ink-400">
          A short message is enough. No sales pressure, no obligation. We reply
          from a human, usually within a day.
        </p>

        <form id="contact-form" data-w3form data-success="Thanks — we'll get back to you shortly." class="mt-10 flex flex-col gap-5">
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="Salvager enterprise enquiry" />
          <input type="hidden" name="from_name" value="Salvager site" />
          <!-- Honeypot: bots fill this, humans never see it. -->
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-ink-200">Name</span>
              <input
                type="text"
                name="name"
                required
                autocomplete="name"
                class="rounded-lg border border-ink-700 bg-ink-900 px-3.5 py-2.5 text-ink-100 placeholder:text-ink-500 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
              />
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-ink-200">Work email</span>
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                class="rounded-lg border border-ink-700 bg-ink-900 px-3.5 py-2.5 text-ink-100 placeholder:text-ink-500 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
              />
            </label>
          </div>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-ink-200">
              Company <span class="text-ink-500">(optional)</span>
            </span>
            <input
              type="text"
              name="company"
              autocomplete="organization"
              class="rounded-lg border border-ink-700 bg-ink-900 px-3.5 py-2.5 text-ink-100 placeholder:text-ink-500 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-ink-200">
              What are you running, and what do you need Salvager to do that it
              doesn't yet?
            </span>
            <textarea
              name="message"
              required
              rows="5"
              placeholder="What you're running it on, team size, and where the open binary stops being enough..."
              class="resize-y rounded-lg border border-ink-700 bg-ink-900 px-3.5 py-2.5 text-ink-100 placeholder:text-ink-500 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
            ></textarea>
          </label>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-500 px-6 py-3 font-medium text-ink-950 transition-colors hover:bg-accent-400 disabled:cursor-not-allowed disabled:opacity-60"
            >
              Send
            </button>
            <p id="contact-status" class="text-sm text-ink-400" data-w3-status role="status" aria-live="polite"></p>
          </div>
        </form>
      </div>
    </section>

    <!-- Salvager Fleet — early access -->
    <section id="fleet" class="border-b border-ink-800/60 bg-ink-900/40 scroll-mt-24">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <p class="font-mono text-sm text-accent-400">Salvager Fleet · early access</p>
        <h2
          class="mt-3 max-w-3xl text-balance text-2xl font-semibold leading-snug tracking-tight text-ink-100 sm:text-3xl"
        >
          One read-only view of what your agents are doing, across every machine.
        </h2>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-300">
          A fleet view built on the open-source core: the denies, checkpoints,
          and recoveries happening across your team's machines, in one place.
          Read-only — it watches, it never drives.
        </p>

        <div class="mt-10 grid gap-5 lg:grid-cols-2">
          <div
            class="rounded-lg border border-accent-600/30 bg-accent-600/[0.07] p-5"
          >
            <h3 class="font-mono text-sm font-semibold text-accent-400">
              Local-first, BYOC
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-300">
              Runs inside your own network, on your own infrastructure. Nothing
              leaves it. The fleet view carries metadata about agent activity —
              not your source, not your files.
            </p>
          </div>
          <div class="rounded-lg border border-ink-700 bg-ink-900 p-5">
            <h3 class="font-mono text-sm font-semibold text-ink-100">
              Private testing
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-300">
              Fleet is in private testing with design partners. It isn't for
              sale yet and there's no pricing to quote. If running Salvager
              across many machines is your problem, we want you in early.
            </p>
          </div>
        </div>

        <form id="fleet-form" data-w3form data-success="Thanks — you're on the early-access list. We'll be in touch." class="mt-10 flex max-w-2xl flex-col gap-5">
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="Salvager Fleet — early access request" />
          <input type="hidden" name="from_name" value="Salvager Fleet (early access)" />
          <!-- Honeypot: bots fill this, humans never see it. -->
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-ink-200">Work email</span>
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                class="rounded-lg border border-ink-700 bg-ink-900 px-3.5 py-2.5 text-ink-100 placeholder:text-ink-500 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
              />
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-ink-200">
                Machines / team size <span class="text-ink-500">(optional)</span>
              </span>
              <input
                type="text"
                name="fleet_size"
                autocomplete="off"
                placeholder="e.g. 30 devs, ~120 machines"
                class="rounded-lg border border-ink-700 bg-ink-900 px-3.5 py-2.5 text-ink-100 placeholder:text-ink-500 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
              />
            </label>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-500 px-6 py-3 font-medium text-ink-950 transition-colors hover:bg-accent-400 disabled:cursor-not-allowed disabled:opacity-60"
            >
              Request early access
            </button>
            <p class="text-sm text-ink-400" data-w3-status role="status" aria-live="polite"></p>
          </div>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // One handler drives every Web3Forms form on the page (enterprise enquiry +
  // fleet early access). Each form carries its own subject/success via markup.
  document.querySelectorAll<HTMLFormElement>("form[data-w3form]").forEach((form) => {
    const status = form.querySelector<HTMLElement>("[data-w3-status]");
    const button = form.querySelector<HTMLButtonElement>("button[type=submit]");
    if (!status || !button) return;
    const success = form.dataset.success ?? "Thanks — we'll be in touch.";
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      button.disabled = true;
      status.textContent = "Sending...";
      status.className = "text-sm text-ink-400";
      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { Accept: "application/json" },
          body: new FormData(form),
        });
        const data = await res.json();
        if (res.ok && data.success) {
          form.reset();
          status.textContent = success;
          status.className = "text-sm text-accent-400";
        } else {
          throw new Error(data.message || "Request failed");
        }
      } catch {
        status.textContent =
          "Something went wrong. Email us directly and we'll sort it out.";
        status.className = "text-sm text-red-400";
      } finally {
        button.disabled = false;
      }
    });
  });
</script>
