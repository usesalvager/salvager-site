---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

// Contact runs through Web3Forms (static-friendly relay). The destination
// inbox is whatever address was used to generate this access key at
// web3forms.com — swap the key to change where submissions land.
// TODO: paste the real Web3Forms access key before launch.
const web3formsKey = "62e8369d-ecf1-45f1-b3a3-20c9f6db36e9";
const repo = "https://github.com/usesalvager/salvager";

const tiers = [
  {
    name: "Community",
    audience: "Solo devs and anyone running it locally.",
    price: "Free, forever",
    priceNote: "Apache-2.0. No accounts, no cloud.",
    features: [
      "The full static binary, every feature",
      "All three MCP tools, full local history",
      "Whole-tree coverage and reversible restore",
      "Community support on GitHub issues",
    ],
    cta: { label: "Get started", href: repo, primary: false },
    highlight: false,
  },
  {
    name: "Supported",
    audience: "Teams putting it into real production.",
    price: "Contact us",
    priceNote: "Scope and price set after a short call.",
    features: [
      "Everything in Community",
      "Hands-on help getting it deployed and supervised",
      "Wiring into your existing tooling and CI",
      "Coverage tuning for large or awkward trees",
      "A written response-time commitment, included",
    ],
    cta: { label: "Talk to us", href: "#contact", primary: true },
    highlight: true,
  },
  {
    name: "Enterprise + Compliance",
    audience: "Regulated orgs: finance, health, public sector, industrial.",
    price: "Contact us",
    priceNote: "Custom scope, set with you.",
    features: [
      "Everything in Supported",
      "Air-gapped and supervised multi-machine deployment",
      "Integration with proprietary stacks (MES, CNC, PLC)",
      "Compliance pack: integrity evidence and a signable audit trail",
      "Named contact and custom SLA on the contract",
    ],
    cta: { label: "Talk to us", href: "#contact", primary: false },
    highlight: false,
  },
];

const services = [
  {
    title: "Integration and deployment",
    body: "Making self-hosted real in a hostile environment: air-gapped installs, the watcher running as a supervised service across many machines, wiring into existing tooling and proprietary MES, CNC and PLC stacks, hardening. This is project work, not a subscription, and it is where the real value sits.",
  },
  {
    title: "Compliance pack",
    body: "The documentation and evidence that Salvager fits an audited change-management process: integrity evidence, an audit trail a human can sign off, and the material a regulated buyer needs to clear their own audit. The pack is a paid deliverable, not part of the open repo.",
  },
  {
    title: "Support and SLA",
    body: "Not a promise to fix bugs, since the binary barely breaks. It is a human contractually obligated to respond if it ever fails in production. It comes bundled with an enterprise engagement, the clause that lets procurement sign, not something sold on its own.",
  },
];

const check = `<path d="M20 6 9 17l-5-5"/>`;
---

<Layout
  title="Salvager for teams: support, deployment and compliance"
  description="The tool stays free and open. When you need guaranteed response times, hands-on deployment, or audit-ready evidence, we work with you directly."
>
  <Header />

  <main id="main">
    <!-- Hero -->
    <section class="border-b border-ink-800/60">
      <div class="mx-auto max-w-5xl px-6 pt-20 pb-16 sm:pt-24">
        <p class="font-mono text-sm text-accent-400">For teams and regulated orgs</p>
        <h1
          class="mt-4 max-w-3xl text-balance text-4xl font-semibold leading-[1.1] tracking-tight text-ink-100 sm:text-5xl"
        >
          Run Salvager with a human behind it.
        </h1>
        <p class="mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-ink-300">
          The tool stays free and open, the same binary everyone runs. When you
          need guaranteed response times, hands-on deployment, or evidence your
          auditor will accept, we work with you directly.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href="#contact"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-500 px-5 py-3 font-medium text-ink-950 transition-colors hover:bg-accent-400"
          >
            Tell us what you're running
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a
            href={repo}
            class="inline-flex items-center justify-center gap-2 rounded-lg border border-ink-700 px-5 py-3 font-medium text-ink-100 transition-colors hover:border-ink-600 hover:bg-ink-850"
          >
            View the source
          </a>
        </div>
      </div>
    </section>

    <!-- Tiers -->
    <section class="border-b border-ink-800/60">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <div class="grid gap-5 lg:grid-cols-3">
          {
            tiers.map((t) => (
              <div
                class={`flex flex-col rounded-xl border bg-ink-900 p-7 ${
                  t.highlight
                    ? "border-accent-600/50 ring-1 ring-accent-600/30"
                    : "border-ink-700"
                }`}
              >
                {t.highlight && (
                  <span class="mb-3 inline-flex w-fit rounded-full bg-accent-600/20 px-2.5 py-0.5 font-mono text-[11px] text-accent-400">
                    Most teams start here
                  </span>
                )}
                <h2 class="text-lg font-semibold text-ink-100">{t.name}</h2>
                <p class="mt-1 text-sm leading-relaxed text-ink-400">
                  {t.audience}
                </p>
                <div class="mt-5">
                  <p class="font-mono text-xl text-ink-100">{t.price}</p>
                  <p class="mt-1 text-xs text-ink-400">{t.priceNote}</p>
                </div>
                <ul class="mt-6 flex flex-1 flex-col gap-2.5">
                  {t.features.map((f) => (
                    <li class="flex items-start gap-2.5 text-sm leading-relaxed text-ink-300">
                      <svg
                        class="mt-0.5 h-4 w-4 shrink-0 text-accent-400"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.25"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                        set:html={check}
                      />
                      {f}
                    </li>
                  ))}
                </ul>
                <a
                  href={t.cta.href}
                  class={`mt-7 inline-flex items-center justify-center gap-2 rounded-lg px-5 py-2.5 font-medium transition-colors ${
                    t.cta.primary
                      ? "bg-accent-500 text-ink-950 hover:bg-accent-400"
                      : "border border-ink-700 text-ink-100 hover:border-ink-600 hover:bg-ink-850"
                  }`}
                >
                  {t.cta.label}
                </a>
              </div>
            ))
          }
        </div>

        <p class="mt-8 max-w-2xl text-sm leading-relaxed text-ink-400">
          No public pricing on purpose. Every team's scope is different, so we
          price after a short call once we understand what you actually need.
          No sales pressure, no obligation.
        </p>
      </div>
    </section>

    <!-- What we do -->
    <section class="border-b border-ink-800/60 bg-ink-900/40">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <p class="font-mono text-sm text-accent-400">What we actually do</p>
        <h2
          class="mt-3 max-w-3xl text-balance text-2xl font-semibold leading-snug tracking-tight text-ink-100 sm:text-3xl"
        >
          Services on top of the open core, not a locked-down version.
        </h2>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-300">
          The core is open, simple, and yours to run for free forever. What you
          can pay for is making it real in your environment and provable to your
          auditors.
        </p>

        <div class="mt-12 grid gap-5 md:grid-cols-3">
          {
            services.map((s) => (
              <div class="rounded-xl border border-ink-700 bg-ink-900 p-6">
                <h3 class="text-base font-semibold text-ink-100">{s.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-ink-300">{s.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="border-b border-ink-800/60 scroll-mt-24">
      <div class="mx-auto max-w-2xl px-6 py-20">
        <h2
          class="text-balance text-2xl font-semibold leading-snug tracking-tight text-ink-100 sm:text-3xl"
        >
          Tell us what you are running, and we will tell you how we can help.
        </h2>
        <p class="mt-3 text-base leading-relaxed text-ink-400">
          A short message is enough. No sales pressure, no obligation. We reply
          from a human, usually within a day.
        </p>

        <form id="contact-form" class="mt-10 flex flex-col gap-5">
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="Salvager enterprise enquiry" />
          <input type="hidden" name="from_name" value="Salvager site" />
          <!-- Honeypot: bots fill this, humans never see it. -->
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-ink-200">Name</span>
              <input
                type="text"
                name="name"
                required
                autocomplete="name"
                class="rounded-lg border border-ink-700 bg-ink-900 px-3.5 py-2.5 text-ink-100 placeholder:text-ink-500 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
              />
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-ink-200">Work email</span>
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                class="rounded-lg border border-ink-700 bg-ink-900 px-3.5 py-2.5 text-ink-100 placeholder:text-ink-500 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
              />
            </label>
          </div>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-ink-200">
              Company <span class="text-ink-500">(optional)</span>
            </span>
            <input
              type="text"
              name="company"
              autocomplete="organization"
              class="rounded-lg border border-ink-700 bg-ink-900 px-3.5 py-2.5 text-ink-100 placeholder:text-ink-500 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-ink-200">
              What are you running, and what do you need?
            </span>
            <textarea
              name="message"
              required
              rows="5"
              placeholder="Environment, team size, what you're trying to make audit-ready or deploy..."
              class="resize-y rounded-lg border border-ink-700 bg-ink-900 px-3.5 py-2.5 text-ink-100 placeholder:text-ink-500 transition-colors focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
            ></textarea>
          </label>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-500 px-6 py-3 font-medium text-ink-950 transition-colors hover:bg-accent-400 disabled:cursor-not-allowed disabled:opacity-60"
            >
              Send
            </button>
            <p id="contact-status" class="text-sm text-ink-400" role="status" aria-live="polite"></p>
          </div>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("contact-status");
  if (form && status) {
    const button = form.querySelector("button[type=submit]") as HTMLButtonElement;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      button.disabled = true;
      status.textContent = "Sending...";
      status.className = "text-sm text-ink-400";
      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { Accept: "application/json" },
          body: new FormData(form),
        });
        const data = await res.json();
        if (res.ok && data.success) {
          form.reset();
          status.textContent = "Thanks — we'll get back to you shortly.";
          status.className = "text-sm text-accent-400";
        } else {
          throw new Error(data.message || "Request failed");
        }
      } catch {
        status.textContent =
          "Something went wrong. Email us directly and we'll sort it out.";
        status.className = "text-sm text-red-400";
      } finally {
        button.disabled = false;
      }
    });
  }
</script>
