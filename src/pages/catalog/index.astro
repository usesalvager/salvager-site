---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import {
  getPublishedCases,
  caseSlug,
  RECOVERABILITY,
  RESPONSE,
  label,
} from "../../lib/catalog";

const cases = await getPublishedCases();

// Build-time facets. Distinct, sorted values for each filterable axis.
const uniq = (xs: string[]) => [...new Set(xs)].sort();
const facets = {
  class: uniq(cases.map((c) => c.data.class)),
  recoverability: uniq(cases.map((c) => c.data.recoverability)),
  salvager_response: uniq(cases.map((c) => c.data.salvager_response)),
  agent: uniq(cases.flatMap((c) => c.data.agent)),
};

const groups = [
  { key: "class", title: "Class", values: facets.class },
  { key: "recoverability", title: "Recoverability", values: facets.recoverability },
  { key: "response", title: "Salvager response", values: facets.salvager_response },
  { key: "agent", title: "Agent", values: facets.agent },
] as const;

const title = "AFM — Agent Failure Modes registry | Salvager";
const description =
  "A registry of AI-agent failure modes with a recoverability axis the security frameworks don't have. Complements MITRE ATLAS and OWASP, doesn't repeat them.";
---

<Layout title={title} description={description}>
  <Header />
  <main id="main">
    <!-- Header / positioning -->
    <section class="border-b border-ink-800/60">
      <div class="mx-auto max-w-5xl px-6 pt-16 pb-12 sm:pt-20">
        <p class="font-mono text-sm text-accent-400">AFM — Agent Failure Modes</p>
        <h1
          class="mt-4 max-w-3xl text-balance text-3xl font-semibold leading-[1.15] tracking-tight text-ink-100 sm:text-4xl"
        >
          A registry of AI-agent failure modes with a recoverability axis the
          security frameworks don&apos;t have.
        </h1>
        <p class="mt-5 max-w-2xl text-pretty text-lg leading-relaxed text-ink-300">
          Complements MITRE ATLAS and OWASP, doesn&apos;t repeat them. Each entry
          maps a real way an agent destroys work to whether — and how — it can be
          recovered. Not an official standard; an open catalog of what breaks and
          what comes back.
        </p>
        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a
            href="/catalog/stix.json"
            class="inline-flex items-center gap-2 rounded-lg border border-accent-600/50 bg-accent-600/10 px-4 py-2.5 font-mono text-sm font-medium text-accent-400 transition-colors hover:bg-accent-600/20"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 7h16M4 12h16M4 17h10"></path>
            </svg>
            STIX 2.1 feed
          </a>
          <span class="font-mono text-xs text-ink-400"
            >Machine-readable · one bundle of attack-patterns + courses-of-action</span
          >
        </div>
      </div>
    </section>

    <!-- Legend -->
    <section class="border-b border-ink-800/60 bg-ink-900/40">
      <div
        class="mx-auto flex max-w-5xl flex-col gap-4 px-6 py-6 sm:flex-row sm:items-start sm:gap-10"
      >
        <div>
          <p class="font-mono text-xs uppercase tracking-wide text-ink-400">
            Recoverability
          </p>
          <div class="mt-2 flex flex-wrap gap-2">
            {
              Object.values(RECOVERABILITY).map((b) => (
                <span
                  class={`rounded-full border px-2.5 py-0.5 text-xs font-medium ${b.cls}`}
                >
                  {b.label}
                </span>
              ))
            }
          </div>
        </div>
        <div>
          <p class="font-mono text-xs uppercase tracking-wide text-ink-400">
            Salvager response
          </p>
          <div class="mt-2 flex flex-wrap gap-2">
            {
              Object.values(RESPONSE).map((b) => (
                <span
                  class={`rounded-full border px-2.5 py-0.5 text-xs font-medium ${b.cls}`}
                >
                  {b.label}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Filters + list -->
    <section>
      <div class="mx-auto max-w-5xl px-6 py-12" data-catalog>
        <div class="grid gap-10 lg:grid-cols-[15rem_1fr]">
          <!-- Filter rail -->
          <aside class="lg:sticky lg:top-20 lg:self-start">
            <div class="flex items-center justify-between">
              <h2 class="font-mono text-sm text-ink-200">Filter</h2>
              <button
                type="button"
                data-clear
                class="hidden text-xs text-ink-400 underline-offset-2 hover:text-ink-100 hover:underline"
                >Clear all</button
              >
            </div>
            <div class="mt-4 space-y-5">
              {
                groups
                  .filter((g) => g.values.length > 0)
                  .map((g) => (
                    <div>
                      <p class="font-mono text-xs uppercase tracking-wide text-ink-400">
                        {g.title}
                      </p>
                      <div class="mt-2 flex flex-wrap gap-1.5">
                        {g.values.map((v) => (
                          <button
                            type="button"
                            data-filter-group={g.key}
                            data-filter-value={v}
                            aria-pressed="false"
                            class="rounded-md border border-ink-700 bg-ink-900 px-2.5 py-1 font-mono text-xs text-ink-300 transition-colors hover:border-ink-600 hover:text-ink-100 aria-pressed:border-accent-600/60 aria-pressed:bg-accent-600/10 aria-pressed:text-accent-400"
                          >
                            {label(v)}
                          </button>
                        ))}
                      </div>
                    </div>
                  ))
              }
            </div>
          </aside>

          <!-- Cards -->
          <div>
            <p class="mb-4 font-mono text-xs text-ink-400" data-count>
              {cases.length} failure {cases.length === 1 ? "mode" : "modes"}
            </p>
            <ul class="space-y-4" data-list>
              {
                cases.map((c) => {
                  const rec = RECOVERABILITY[c.data.recoverability];
                  const res = RESPONSE[c.data.salvager_response];
                  return (
                    <li
                      data-card
                      data-class={c.data.class}
                      data-recoverability={c.data.recoverability}
                      data-response={c.data.salvager_response}
                      data-agent={c.data.agent.join(" ")}
                    >
                      <a
                        href={`/catalog/${caseSlug(c)}`}
                        class="block rounded-xl border border-ink-700 bg-ink-950/80 p-5 transition-colors hover:border-ink-600 hover:bg-ink-900/60"
                      >
                        <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
                          <span class="font-mono text-xs text-accent-400">
                            {c.data.id}
                          </span>
                          <span class="font-mono text-xs text-ink-500">
                            {label(c.data.class)}
                          </span>
                          <span class="ml-auto flex flex-wrap gap-1.5">
                            <span
                              class={`rounded-full border px-2.5 py-0.5 text-xs font-medium ${rec.cls}`}
                            >
                              {rec.label}
                            </span>
                            <span
                              class={`rounded-full border px-2.5 py-0.5 text-xs font-medium ${res.cls}`}
                            >
                              {res.label}
                            </span>
                          </span>
                        </div>
                        <h3 class="mt-3 text-balance text-lg font-semibold leading-snug text-ink-100">
                          {c.data.title}
                        </h3>
                        <p class="mt-2 text-pretty leading-relaxed text-ink-300">
                          {c.data.one_liner}
                        </p>
                        {c.data.agent.length > 0 && (
                          <div class="mt-3 flex flex-wrap gap-1.5">
                            {c.data.agent.map((a) => (
                              <span class="rounded border border-ink-700 bg-ink-850 px-2 py-0.5 font-mono text-[11px] text-ink-300">
                                {a}
                              </span>
                            ))}
                          </div>
                        )}
                      </a>
                    </li>
                  );
                })
              }
            </ul>
            <p
              data-empty
              hidden
              class="rounded-xl border border-dashed border-ink-700 p-8 text-center text-ink-400"
            >
              No failure modes match those filters.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  // Client-side facet filtering. Within a group, active values OR together;
  // across groups they AND. No framework — the full list is server-rendered and
  // filtering only toggles visibility.
  const root = document.querySelector<HTMLElement>("[data-catalog]");
  if (root) {
    const buttons = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-filter-group]"),
    );
    const cards = Array.from(root.querySelectorAll<HTMLElement>("[data-card]"));
    const countEl = root.querySelector<HTMLElement>("[data-count]");
    const emptyEl = root.querySelector<HTMLElement>("[data-empty]");
    const clearBtn = root.querySelector<HTMLButtonElement>("[data-clear]");

    const matches = (card: HTMLElement, group: string, value: string) => {
      if (group === "agent")
        return (card.dataset.agent ?? "").split(" ").includes(value);
      const map: Record<string, string | undefined> = {
        class: card.dataset.class,
        recoverability: card.dataset.recoverability,
        response: card.dataset.response,
      };
      return map[group] === value;
    };

    const apply = () => {
      // Collect active values per group.
      const active = new Map<string, string[]>();
      for (const b of buttons) {
        if (b.getAttribute("aria-pressed") !== "true") continue;
        const g = b.dataset.filterGroup!;
        (active.get(g) ?? active.set(g, []).get(g)!).push(b.dataset.filterValue!);
      }
      let shown = 0;
      for (const card of cards) {
        const visible = [...active].every(([g, vals]) =>
          vals.some((v) => matches(card, g, v)),
        );
        card.hidden = !visible;
        if (visible) shown++;
      }
      if (countEl)
        countEl.textContent = `${shown} failure mode${shown === 1 ? "" : "s"}`;
      if (emptyEl) emptyEl.hidden = shown !== 0;
      if (clearBtn) clearBtn.classList.toggle("hidden", active.size === 0);
    };

    buttons.forEach((b) =>
      b.addEventListener("click", () => {
        b.setAttribute(
          "aria-pressed",
          b.getAttribute("aria-pressed") === "true" ? "false" : "true",
        );
        apply();
      }),
    );
    clearBtn?.addEventListener("click", () => {
      buttons.forEach((b) => b.setAttribute("aria-pressed", "false"));
      apply();
    });
  }
</script>
