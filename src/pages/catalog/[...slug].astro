---
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import {
  getPublishedCases,
  getPublishedById,
  caseSlug,
  RECOVERABILITY,
  RESPONSE,
  NEUTRAL,
  label,
  type Case,
} from "../../lib/catalog";

export async function getStaticPaths() {
  const cases = await getPublishedCases();
  return cases.map((entry) => ({ params: { slug: caseSlug(entry) }, props: { entry } }));
}

const { entry } = Astro.props as { entry: Case };
const d = entry.data;
const { Content } = await render(entry);

// Resolve ChildOf/ParentOf relationships to their published slugs (drop dangling).
const byId = await getPublishedById();
const rels = d.relationships
  .map((r) => ({ nature: r.nature, target: byId.get(r.id) }))
  .filter((r): r is { nature: typeof r.nature; target: Case } => Boolean(r.target));

const rec = RECOVERABILITY[d.recoverability];
const res = RESPONSE[d.salvager_response];
const stixHref = `/catalog/${d.id.toLowerCase()}.stix.json`;

const title = `${d.id}: ${d.title} | Salvager AFM`;
---

<Layout title={title} description={d.one_liner}>
  <Header />
  <main id="main">
    <article class="mx-auto max-w-3xl px-6 py-14 sm:py-16">
      <a
        href="/catalog"
        class="inline-flex items-center gap-1.5 font-mono text-sm text-ink-400 transition-colors hover:text-ink-100"
      >
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        AFM registry
      </a>

      <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2">
        <span class="font-mono text-sm text-accent-400">{d.id}</span>
        <span class="font-mono text-xs text-ink-500">{label(d.class)}</span>
      </div>
      <h1
        class="mt-3 text-balance text-2xl font-semibold leading-tight tracking-tight text-ink-100 sm:text-3xl"
      >
        {d.title}
      </h1>
      <p class="mt-4 text-pretty text-lg leading-relaxed text-ink-300">
        {d.one_liner}
      </p>

      <!-- Axis badges -->
      <div class="mt-6 flex flex-wrap gap-2">
        <span class={`rounded-full border px-3 py-1 text-xs font-medium ${rec.cls}`}>
          {rec.label}
        </span>
        <span class={`rounded-full border px-3 py-1 text-xs font-medium ${res.cls}`}>
          {res.label}
        </span>
        <span class={`rounded-full border px-3 py-1 text-xs font-medium ${NEUTRAL}`}>
          Intent: {label(d.intent)}
        </span>
        <span class={`rounded-full border px-3 py-1 text-xs font-medium ${NEUTRAL}`}>
          Blast radius: {label(d.blast_radius)}
        </span>
      </div>

      {
        d.agent.length > 0 && (
          <div class="mt-3 flex flex-wrap items-center gap-1.5">
            <span class="font-mono text-xs text-ink-500">Agent:</span>
            {d.agent.map((a) => (
              <span class="rounded border border-ink-700 bg-ink-850 px-2 py-0.5 font-mono text-[11px] text-ink-300">
                {a}
              </span>
            ))}
          </div>
        )
      }

      <!-- Prose body -->
      <div class="afm-prose mt-10">
        <Content />
      </div>

      <!-- Sources -->
      <section class="mt-12 border-t border-ink-800/60 pt-8">
        <h2 class="font-mono text-sm uppercase tracking-wide text-ink-400">Sources</h2>
        <ul class="mt-3 space-y-2">
          {
            d.sources.map((s) => (
              <li class="text-ink-300">
                {s.url ? (
                  <a
                    href={s.url}
                    rel="nofollow noopener"
                    target="_blank"
                    class="text-accent-400 underline-offset-2 hover:underline"
                  >
                    {s.name}
                  </a>
                ) : (
                  <span>{s.name}</span>
                )}
                {s.tags.length > 0 && (
                  <span class="ml-2 font-mono text-xs text-ink-500">
                    {s.tags.map((t) => `#${t}`).join(" ")}
                  </span>
                )}
              </li>
            ))
          }
        </ul>
      </section>

      <!-- External references (xrefs) -->
      {
        d.xrefs.length > 0 && (
          <section class="mt-8 border-t border-ink-800/60 pt-8">
            <h2 class="font-mono text-sm uppercase tracking-wide text-ink-400">
              External references
            </h2>
            <ul class="mt-3 space-y-2">
              {d.xrefs.map((x) => (
                <li>
                  <a
                    href={x.url}
                    rel="nofollow noopener"
                    target="_blank"
                    class="text-accent-400 underline-offset-2 hover:underline"
                  >
                    <span class="font-mono text-xs uppercase text-ink-500">
                      {x.source_name}
                    </span>{" "}
                    {x.external_id}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <!-- Relationships -->
      {
        rels.length > 0 && (
          <section class="mt-8 border-t border-ink-800/60 pt-8">
            <h2 class="font-mono text-sm uppercase tracking-wide text-ink-400">
              Relationships
            </h2>
            <ul class="mt-3 space-y-2">
              {rels.map((r) => (
                <li class="text-ink-300">
                  <span class="font-mono text-xs text-ink-500">
                    {r.nature === "child_of" ? "ChildOf" : "ParentOf"}
                  </span>{" "}
                  <a
                    href={`/catalog/${caseSlug(r.target)}`}
                    class="text-accent-400 underline-offset-2 hover:underline"
                  >
                    {r.target.data.id} — {r.target.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <!-- Machine-readable -->
      <section class="mt-10 border-t border-ink-800/60 pt-8">
        <a
          href={stixHref}
          class="inline-flex items-center gap-2 font-mono text-sm text-ink-400 transition-colors hover:text-accent-400"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h10"></path>
          </svg>
          STIX 2.1 for {d.id}
        </a>
      </section>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  /* Minimal prose styling — no typography plugin installed; keep it on-brand. */
  .afm-prose :global(h2) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink-100);
  }
  .afm-prose :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
    color: var(--color-ink-200);
  }
  .afm-prose :global(ul) {
    margin-bottom: 1rem;
    padding-left: 1.25rem;
    list-style: disc;
    color: var(--color-ink-200);
  }
  .afm-prose :global(li) {
    margin-bottom: 0.35rem;
  }
  .afm-prose :global(a) {
    color: var(--color-accent-400);
    text-underline-offset: 2px;
  }
  .afm-prose :global(a:hover) {
    text-decoration: underline;
  }
  .afm-prose :global(code) {
    border-radius: 0.25rem;
    background: var(--color-ink-850);
    padding: 0.1rem 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--color-ink-100);
  }
  .afm-prose :global(strong) {
    color: var(--color-ink-100);
    font-weight: 600;
  }
  .afm-prose :global(blockquote) {
    margin: 1.25rem 0;
    border-left: 2px solid var(--color-accent-600);
    background: var(--color-ink-900);
    padding: 0.75rem 1rem;
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--color-ink-300);
  }
  .afm-prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }
</style>
