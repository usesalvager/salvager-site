---
// A copyable code block. Renders the raw command/snippet in monospace with a
// copy button. The copy behaviour is wired once, globally, in index.astro via
// event delegation on [data-copy] — keeps JS to a few lines.
interface Props {
  code: string;
  /** Optional label shown in the top bar, e.g. "shell" or "json". */
  label?: string;
}
const { code, label } = Astro.props;
---

<div
  class="group relative overflow-hidden rounded-lg border border-ink-700 bg-ink-900"
>
  <div
    class="flex items-center justify-between border-b border-ink-700/70 bg-ink-850 px-4 py-2"
  >
    <span class="font-mono text-xs text-ink-400">{label ?? "shell"}</span>
    <button
      type="button"
      data-copy
      class="inline-flex items-center gap-1.5 rounded-md px-2 py-1 font-mono text-xs text-ink-400 transition-colors hover:text-ink-100"
      aria-label="Copy to clipboard"
    >
      <svg
        class="copy-icon h-3.5 w-3.5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <rect x="9" y="9" width="13" height="13" rx="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <span class="copy-label">Copy</span>
    </button>
  </div>
  <pre
    class="overflow-x-auto px-4 py-3.5 font-mono text-sm leading-relaxed text-ink-100"><code>{code}</code></pre>
</div>
