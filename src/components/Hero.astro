---
import CodeBlock from "./CodeBlock.astro";
const repo = "https://github.com/usesalvager/salvager";
---

<section
  id="top"
  class="relative overflow-hidden border-b border-ink-800/60"
>
  <!-- subtle revision-stack motif as a faint background grid -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 opacity-[0.18]"
    style="background-image: linear-gradient(to right, #1a1f29 1px, transparent 1px), linear-gradient(to bottom, #1a1f29 1px, transparent 1px); background-size: 56px 56px; mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black, transparent 75%);"
  >
  </div>

  <div class="relative mx-auto max-w-5xl px-6 pt-20 pb-20 sm:pt-28">
    <h1
      class="max-w-3xl text-balance text-4xl font-semibold leading-[1.1] tracking-tight text-ink-100 sm:text-5xl md:text-6xl"
    >
      Let agents edit your code.
      <span class="text-accent-400">Keep every version.</span>
    </h1>

    <p class="mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-ink-300">
      Salvager is a filesystem-level safety net for AI coding agents. A passive
      watcher saves every file revision as you and your agent work, so anything
      the agent breaks, you can get back.
    </p>

    <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
      <a
        href={repo}
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-500 px-5 py-3 font-medium text-ink-950 transition-colors hover:bg-accent-400"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.21 3.44 9.63 8.2 11.19.6.11.82-.25.82-.56v-2c-3.34.71-4.04-1.58-4.04-1.58-.55-1.36-1.34-1.72-1.34-1.72-1.09-.73.08-.72.08-.72 1.2.08 1.84 1.22 1.84 1.22 1.07 1.8 2.81 1.28 3.5.98.11-.76.42-1.28.76-1.57-2.67-.3-5.47-1.31-5.47-5.84 0-1.29.47-2.34 1.23-3.17-.12-.3-.53-1.52.12-3.16 0 0 1.01-.32 3.3 1.21a11.6 11.6 0 0 1 6 0c2.29-1.53 3.3-1.21 3.3-1.21.65 1.64.24 2.86.12 3.16.77.83 1.23 1.88 1.23 3.17 0 4.54-2.81 5.53-5.49 5.83.43.37.81 1.1.81 2.22v3.29c0 .31.22.68.83.56A12.01 12.01 0 0 0 24 12.29C24 5.78 18.63.5 12 .5Z"
          ></path>
        </svg>
        View on GitHub
      </a>
      <a
        href="#how"
        class="inline-flex items-center justify-center gap-2 rounded-lg border border-ink-700 px-5 py-3 font-medium text-ink-100 transition-colors hover:border-ink-600 hover:bg-ink-850"
      >
        How it works
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 5v14M19 12l-7 7-7-7"></path>
        </svg>
      </a>
    </div>

    <div class="mt-10 max-w-xl">
      <p class="mb-2 font-mono text-xs text-ink-400">
        Zero config. Run it in any project root:
      </p>
      <CodeBlock label="shell" code="salvager watch" />
    </div>
  </div>
</section>
