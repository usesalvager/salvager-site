---
const repo = "https://github.com/usesalvager/salvager";
const license = "https://github.com/usesalvager/salvager/blob/main/LICENSE";
---

<footer class="bg-ink-950">
  <div
    class="mx-auto flex max-w-5xl flex-col gap-6 px-6 py-12 sm:flex-row sm:items-center sm:justify-between"
  >
    <div class="flex items-center gap-2.5">
      <svg class="h-5 w-5" viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="9" cy="9" r="2.4" fill="#18bda9"></circle>
        <circle cx="9" cy="16" r="2.4" fill="#18bda9"></circle>
        <circle cx="9" cy="23" r="2.4" fill="#38d6c4"></circle>
        <rect x="15" y="7.5" width="10" height="3" rx="1.5" fill="#323a49"
        ></rect>
        <rect x="15" y="14.5" width="10" height="3" rx="1.5" fill="#323a49"
        ></rect>
        <rect x="15" y="21.5" width="10" height="3" rx="1.5" fill="#7c8597"
        ></rect>
      </svg>
      <span class="font-mono text-sm text-ink-300">salvager.sh</span>
    </div>

    <nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
      <a
        href="/catalog"
        class="text-ink-300 transition-colors hover:text-ink-100">Catalog</a
      >
      <a
        href="/enterprise"
        class="text-ink-300 transition-colors hover:text-ink-100">Enterprise</a
      >
      <a
        href={repo}
        class="text-ink-300 transition-colors hover:text-ink-100">GitHub</a
      >
      <a
        href={license}
        class="text-ink-300 transition-colors hover:text-ink-100"
        >Apache-2.0</a
      >
      <span class="font-mono text-xs text-ink-400"
        >The watcher is the guarantee.</span
      >
    </nav>
  </div>
</footer>
