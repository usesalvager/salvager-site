---
const repo = "https://github.com/usesalvager/salvager";
---

<header
  class="sticky top-0 z-40 border-b border-ink-800/80 bg-ink-950/80 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3.5">
    <a href="#top" class="flex items-center gap-2.5" aria-label="Salvager home">
      <svg class="h-6 w-6" viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="9" cy="9" r="2.4" fill="#18bda9"></circle>
        <circle cx="9" cy="16" r="2.4" fill="#18bda9"></circle>
        <circle cx="9" cy="23" r="2.4" fill="#38d6c4"></circle>
        <line x1="9" y1="11" x2="9" y2="14" stroke="#323a49" stroke-width="1.5"
        ></line>
        <line x1="9" y1="18" x2="9" y2="21" stroke="#323a49" stroke-width="1.5"
        ></line>
        <rect x="15" y="7.5" width="10" height="3" rx="1.5" fill="#323a49"
        ></rect>
        <rect x="15" y="14.5" width="10" height="3" rx="1.5" fill="#323a49"
        ></rect>
        <rect x="15" y="21.5" width="10" height="3" rx="1.5" fill="#7c8597"
        ></rect>
      </svg>
      <span class="font-mono text-base font-semibold tracking-tight text-ink-100"
        >salvager</span
      >
    </a>

    <nav class="flex items-center gap-1 sm:gap-2 text-sm">
      <a
        href="#how"
        class="hidden rounded-md px-3 py-1.5 text-ink-300 transition-colors hover:text-ink-100 sm:inline-block"
        >How it works</a
      >
      <a
        href="#agents"
        class="hidden rounded-md px-3 py-1.5 text-ink-300 transition-colors hover:text-ink-100 sm:inline-block"
        >For agents</a
      >
      <a
        href="#quickstart"
        class="hidden rounded-md px-3 py-1.5 text-ink-300 transition-colors hover:text-ink-100 sm:inline-block"
        >Quickstart</a
      >
      <a
        href="#faq"
        class="hidden rounded-md px-3 py-1.5 text-ink-300 transition-colors hover:text-ink-100 sm:inline-block"
        >FAQ</a
      >
      <a
        href={repo}
        class="inline-flex items-center gap-2 rounded-md border border-ink-700 px-3 py-1.5 font-medium text-ink-100 transition-colors hover:border-ink-600 hover:bg-ink-850"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.21 3.44 9.63 8.2 11.19.6.11.82-.25.82-.56v-2c-3.34.71-4.04-1.58-4.04-1.58-.55-1.36-1.34-1.72-1.34-1.72-1.09-.73.08-.72.08-.72 1.2.08 1.84 1.22 1.84 1.22 1.07 1.8 2.81 1.28 3.5.98.11-.76.42-1.28.76-1.57-2.67-.3-5.47-1.31-5.47-5.84 0-1.29.47-2.34 1.23-3.17-.12-.3-.53-1.52.12-3.16 0 0 1.01-.32 3.3 1.21a11.6 11.6 0 0 1 6 0c2.29-1.53 3.3-1.21 3.3-1.21.65 1.64.24 2.86.12 3.16.77.83 1.23 1.88 1.23 3.17 0 4.54-2.81 5.53-5.49 5.83.43.37.81 1.1.81 2.22v3.29c0 .31.22.68.83.56A12.01 12.01 0 0 0 24 12.29C24 5.78 18.63.5 12 .5Z"
          ></path>
        </svg>
        <span>GitHub</span>
      </a>
    </nav>
  </div>
</header>
